# Python bot (aiogram) settings
BOT_TOKEN=your_bot_token_here
CHECKO_API_KEY=your_checko_api_key_here
CHECKO_API_URL=https://api.checko.ru/v2
DATABASE_PATH=bot.db

# Optional: download initial SQLite DB from HTTP(S) URL if DATABASE_PATH does not exist
# DATABASE_SOURCE_URL=https://<your-r2-domain>/your-database.db

# Optional: maximum Telegram API reconnect attempts before exit (polling mode)
# POLLING_MAX_RETRIES=5

# Optional: python webhook mode
# WEBHOOK_BASE_URL=https://your-domain.example
# WEBHOOK_PATH=/webhook
# WEBHOOK_SECRET_TOKEN=change_me
# WEBHOOK_HOST=0.0.0.0
# WEBHOOK_PORT=8080

# Cloudflare Worker secrets (set via wrangler secret put in production)
TELEGRAM_BOT_TOKEN=
WEBHOOK_SECRET=

DADATA_API_KEY=
DADATA_SECRET_KEY=
DADATA_API_URL=https://suggestions.dadata.ru/suggestions/api/4_1/rs
