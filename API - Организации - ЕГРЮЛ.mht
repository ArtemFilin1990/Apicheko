@charset "utf-8";

.cp-note { display: inline-block; padding: 0.4rem 1rem; background-color: rgb(255, 230, 170); box-shadow: var(--shadow-md); line-height: 1.5; }

.cp-note.pointer:hover { background-color: rgb(255, 220, 136); }

.cp-note-small { display: inline-block; margin: 0.5rem 0px; padding: 0.3rem 0.7rem; background-color: rgb(255, 230, 170); box-shadow: var(--shadow-md); line-height: 1.25; }

.cp-tags a:not(.show-on-hover), .cp-tags a:not(.show-on-hover):visited { display: inline-block; margin: 1rem 0.25rem -1rem 0px; padding: 4px 12px; border-radius: 32px; }

.cp-tags a:last-of-type { margin-right: 1rem; }

.small-tags a:not(.show-on-hover), .small-tags a:not(.show-on-hover):visited { display: inline-block; margin: 0.5rem 0.25rem -1rem 0px; padding: 2px 10px; border-radius: 25px; font-size: 14px; }

.small-tags a.show-on-hover { margin-left: 0.25rem; }

.cp-tags a { background-color: var(--bs-gray-600); }

.tag-red { background-color: rgb(243, 52, 38) !important; color: rgb(255, 255, 255); }

.tag-orange { background-color: rgb(254, 134, 0) !important; color: rgb(255, 255, 255); }

.tag-green { background-color: rgb(71, 163, 75) !important; color: rgb(255, 255, 255); }

.tag-blue { background-color: rgb(12, 133, 230) !important; color: rgb(255, 255, 255); }

.tag-purple { background-color: rgb(156, 39, 176) !important; color: rgb(255, 255, 255); }

.tag-brown { background-color: rgb(132, 92, 78) !important; color: rgb(255, 255, 255); }

.tag-black { background-color: rgb(17, 17, 17) !important; color: rgb(255, 255, 255); }

.tag-default { background-color: var(--bs-gray-600) !important; color: rgb(255, 255, 255); }

.tag-red:hover { background-color: rgb(234, 28, 13) !important; }

.tag-orange:hover { background-color: rgb(237, 125, 0) !important; }

.tag-green:hover { background-color: rgb(66, 151, 70) !important; }

.tag-blue:hover { background-color: rgb(11, 124, 214) !important; }

.tag-purple:hover { background-color: rgb(144, 36, 162) !important; }

.tag-brown:hover { background-color: rgb(121, 85, 72) !important; }

.tag-black:hover { background-color: rgb(0, 0, 0) !important; }

