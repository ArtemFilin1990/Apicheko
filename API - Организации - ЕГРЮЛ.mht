.dropzone-form .dz-preview .dz-details .dz-size { font-size: 0.875rem; padding-bottom: 0.25rem; }

.dropzone-form .dz-preview .dz-details .dz-filename { color: rgb(255, 255, 255); background-color: rgb(51, 51, 51); overflow: hidden; }

.dropzone-form .dz-preview .dz-details .dz-filename:hover span { color: rgb(255, 255, 255); background-color: rgb(51, 51, 51); }

.dropzone-form .dz-preview .dz-details .dz-filename:not(:hover) { overflow: hidden; }

